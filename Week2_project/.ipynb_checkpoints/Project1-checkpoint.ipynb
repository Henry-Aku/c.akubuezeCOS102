   "id": "63810c73-fd1d-4a25-a77a-c7610a8fa1ed",
   "metadata": {},
   "source": [
    "BEGIN StoreCheckout\n",
    "    SET Total = 0\n",
    "    REPEAT\n",
    "        INPUT ItemPrice\n",
    "        Total = Total + ItemPrice\n",
    "        INPUT MoreItems? (Yes/No)\n",
    "    UNTIL MoreItems == No\n",
    "    \n",
    "    SET Tax = Total * 0.08  (Assuming 8% tax)\n",
    "    SET FinalAmount = Total + Tax\n",
    "    DISPLAY FinalAmount\n",
    "    \n",
    "    INPUT PaymentType (Cash or Card)\n",
    "    IF PaymentType == \"Card\" THEN\n",
    "        PROCESS CardTransaction\n",
    "    ELSE\n",
    "        INPUT CashReceived\n",
    "        SET Change = CashReceived - FinalAmount\n",
    "        DISPLAY Change\n",
    "    ENDIF\n",
    "    \n",
    "    PRINT Receipt\n",
    "    DISPLAY \"Thank you for shopping!\"\n",
    "END"
   ]
  },
